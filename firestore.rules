rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /mission_queue/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /execution_reports/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
